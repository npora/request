{
  "name": "@npora/request",
  "version": "0.1.0",
  "description": "A modern, TypeScript-first HTTP client powered by the Fetch API.",
  "keywords": [
    "npora",
    "request",
    "fetch",
    "http",
    "http-client",
    "typescript"
  ],
  "homepage": "https://github.com/npora/request",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/npora/request.git"
  },
  "bugs": {
    "url": "https://github.com/npora/request/issues"
  },
  "license": "MIT",
  "author": "Npora Team",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.10.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "example": "tsx examples/basic.ts",
    "example:plugins": "tsx examples/plugins.ts",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
